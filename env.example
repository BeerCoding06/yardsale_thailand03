# =================
# Application (Nuxt-only storefront — mock catalog in server/utils/mock-catalog.ts)
# =================
BASE_URL=http://localhost:3000

# Yardsale API (Express + PostgreSQL) — ตั้งค่าแล้ว login / admin / create-user จะยิงไปที่เซิร์ฟเวอร์จริง (ไม่ใช้ mock /api)
#
# Dev แนะนำ (เลี่ยง CORS / "Failed to fetch"): ใช้ proxy ใน nuxt.config → รัน backend ที่พอร์ต 4000
NUXT_PUBLIC_CMS_API_BASE=/yardsale-api
# ถ้าต้องการยิงตรงไปที่ Express (เบราว์เซอร์อาจบล็อกข้ามพอร์ต):
# NUXT_PUBLIC_CMS_API_BASE=http://127.0.0.1:4000/api
#
# ถ้า Express ไม่ได้อยู่ที่ 4000:
# NUXT_YARDSALE_PROXY_TARGET=http://127.0.0.1:PORT
#
# รูปสินค้าเป็น path สัมพัทธ์ (/uploads/...) — ตั้ง origin ของ Express ให้ NuxtImg โหลดได้ (ค่าเริ่ม 127.0.0.1:4000)
# NUXT_PUBLIC_YARDSALE_BACKEND_ORIGIN=http://127.0.0.1:4000
#
# @nuxt/image (IPX) — ต้องใส่โดเมนที่โหลดรูปสินค้าได้ ไม่งั้นรายการสินค้า/แก้ไขจะไม่แสดงรูป
# Production (API คนละโดเมนกับหน้าเว็บ): ใส่ทั้ง API + เว็บ เช่น
# NUXT_IMAGE_DOMAINS=api.yardsaleth.com,www.yardsaleth.com,yardsaleth.com
# Dev:
# NUXT_IMAGE_DOMAINS=127.0.0.1,localhost
#
# ถ้า NUXT_PUBLIC_CMS_API_BASE เป็น URL เต็ม https://api.example.com/api มักไม่ต้องตั้ง YARDSALE_BACKEND_ORIGIN
# ถ้าเป็น path /yardsale-api อย่างเดียว — บน production ที่ API อยู่คนละโดเมน ให้ตั้ง:
# NUXT_PUBLIC_YARDSALE_BACKEND_ORIGIN=https://api.example.com

# Dev: ถ้าแก้ HMR เอง ต้องให้ client ต่อ WebSocket ได้จริง (ค่าเริ่มของ Nuxt ใช้พอร์ต dev เดียวกัน)
# NUXT_VITE_HMR_PORT=3000
# NUXT_VITE_HMR_CLIENT_PORT=3000

# Wrangler (NuxtHub): เขียน log ในโปรเจกต์ แทน ~/Library/Preferences/.wrangler/ (กัน EACCES)
# ตั้งใน package.json script แล้ว: WRANGLER_LOG_DIR=.wrangler-logs

# =================
# Firebase Cloud Messaging (Vue/Nuxt)
# =================
# API ที่มี /api/save-token และ /api/send-notification (Laravel หรือ Yardsale Express)
# ถ้าว่าง — จะใช้ URL จาก NUXT_PUBLIC_CMS_API_BASE แทน (Express ตัวเดียวกับเว็บ)
# NUXT_PUBLIC_LARAVEL_API_BASE=http://127.0.0.1:4000

NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_VAPID_KEY=

