# pnpm configuration — ลด ECONNRESET จาก registry ระหว่าง Docker/CI
fetch-timeout=300000
fetch-retries=10
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
# ลด concurrent บางครั้งเสถียรกว่าเมื่อ registry รีเซ็ต connection
network-concurrency=6

# Use shamefully-hoist to work around peer dependency issues
shamefully-hoist=true

# Auto install peers
auto-install-peers=true

# Ignore scripts for problematic packages
ignore-scripts=false
