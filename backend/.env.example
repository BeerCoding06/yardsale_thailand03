PORT=4000
NODE_ENV=development

# สร้าง DB ก่อน: createdb yardsale
#
# macOS + Homebrew Postgres มักไม่มี role ชื่อ "postgres" → error role "postgres" does not exist
# แก้โดยใช้ user เดียวกับชื่อ mac ของคุณ (รัน whoami) หรือไม่ใส่ user ใน URI (pg จะใช้ชื่อ user ปัจจุบันของระบบ)
#
# ตัวอย่าง (ไม่ระบุ user — pg ใช้ชื่อ user ระบบ หรือค่า PGUSER):
DATABASE_URL=postgresql://127.0.0.1:5432/yardsale
#
# ถ้ายังขึ้น role "postgres" does not exist ให้เช็ก: echo $PGUSER
# ถ้าได้ postgres ให้ unset PGUSER หรือตั้ง explicit user แบบบรรทัดล่าง
#
# ตัวอย่าง (ระบุ user ชัดเจน — แทน YOUR_MAC_USER ด้วยผลจาก whoami):
# DATABASE_URL=postgresql://YOUR_MAC_USER@127.0.0.1:5432/yardsale
#
# Docker / Linux คลาสสิกที่มี role postgres:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/yardsale

JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# --- OAuth / social login (Express /auth/*) — คู่มือ: docs/SOCIAL_AUTH_SETUP.md ---
# URL สาธารณะของ API ที่ผู้ให้บริการ OAuth redirect กลับมา (ต้องตรงกับที่ลงทะเบียนใน Console)
# OAUTH_CALLBACK_BASE=http://127.0.0.1:4000
# หลังล็อกอินสำเร็จ redirect ไปหน้า Nuxt (รับ query ?token=&refresh=)
# OAUTH_FRONTEND_SUCCESS_URL=http://localhost:3000/auth/callback
# OAUTH_FRONTEND_FAILURE_URL=http://localhost:3000/auth/callback
# SESSION_SECRET=another-long-random-string
# JWT_REFRESH_SECRET=refresh-secret-different-from-jwt
# JWT_REFRESH_EXPIRES_IN=30d
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# LINE_CHANNEL_ID=
# LINE_CHANNEL_SECRET=

# Super admin: อีเมลที่แก้ไขได้เฉพาะเจ้าของบัญชี — แอดมินคนอื่น PATCH/DELETE ไม่ได้ (คั่นหลายอีเมลด้วย comma)
# SUPER_ADMIN_EMAILS=paradon.pokpingmaung@gmail.com

UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_BASE=/uploads

# Optional: คั่นด้วย comma ถ้าต้องการจำกัด origin (ค่าเริ่ม = รับทุก origin ที่ส่งมา)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SlipOK (ตรวจสลิปผ่าน /api/payment/mock)
# SLIPOK_BRANCH_ID=63381
# SLIPOK_API_KEY=your-slipok-api-key
# SLIPOK_API_BASE=https://api.slipok.com
# SLIPOK_LOG_DEFAULT=true
#
# ส่ง body ได้อย่างใดอย่างหนึ่ง:
# - slip_data (qr string)
# - slip_url  (url รูป)
# - slip_image (multipart file field)
# optional: amount, log
#
# ชั่วคราว: log JSON บรรทัดเดียว [payment-audit] หลังชำระ/SlipOK (grep ใน Dokploy)
# PAYMENT_AUDIT_LOG=1

# Firebase Cloud Messaging (Firebase Admin SDK) — ใช้อย่างใดอย่างหนึ่ง (ห้าม commit credentials)
#
# วิธี A: ไฟล์ service account
# FIREBASE_PROJECT_ID=your-gcp-project-id
# FIREBASE_CREDENTIALS=/absolute/path/to/service-account.json
#
# วิธี B: JSON ทั้งก้อน (Dokploy secret)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
#
# วิธี C: แยกตัวแปร (Docker / CI นิยม — private key ใส่ \n เป็น literal สองอักขระ)
# FIREBASE_PROJECT_ID=your-gcp-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@....iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n....\n-----END PRIVATE KEY-----\n"
#
# ลิงก์ใน push (คลิกแจ้งเตือน) — ไม่ตั้งจะใช้ origin แรกจาก CORS_ORIGINS
# PUBLIC_WEB_URL=https://www.yardsaleth.com
#
# จำกัดความถี่ broadcast (ต่อแอดมิน+IP ต่อนาที)
# FCM_BROADCAST_RATE_LIMIT_PER_MINUTE=5
# FCM_SEND_NOTIFICATION_RATE_LIMIT_PER_MINUTE=30
# FCM_BROADCAST_DELAY_MS=80
# FCM_BROADCAST_PAGE_SIZE=500

# seed-demo.js — บัญชีแอดมินสำหรับหน้า /admin (ค่าเริ่ม)
# SEED_ADMIN_EMAIL=admin@demo.local
# SEED_ADMIN_PASSWORD=admin123456
# รหัสแอดมินเดิมลืม: SEED_RESET_ADMIN_PASSWORD=1 npm run db:seed
