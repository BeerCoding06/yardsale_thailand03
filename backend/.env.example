PORT=4000
NODE_ENV=development

# สร้าง DB ก่อน: createdb yardsale
#
# macOS + Homebrew Postgres มักไม่มี role ชื่อ "postgres" → error role "postgres" does not exist
# แก้โดยใช้ user เดียวกับชื่อ mac ของคุณ (รัน whoami) หรือไม่ใส่ user ใน URI (pg จะใช้ชื่อ user ปัจจุบันของระบบ)
#
# ตัวอย่าง (ไม่ระบุ user — pg ใช้ชื่อ user ระบบ หรือค่า PGUSER):
DATABASE_URL=postgresql://127.0.0.1:5432/yardsale
#
# ถ้ายังขึ้น role "postgres" does not exist ให้เช็ก: echo $PGUSER
# ถ้าได้ postgres ให้ unset PGUSER หรือตั้ง explicit user แบบบรรทัดล่าง
#
# ตัวอย่าง (ระบุ user ชัดเจน — แทน YOUR_MAC_USER ด้วยผลจาก whoami):
# DATABASE_URL=postgresql://YOUR_MAC_USER@127.0.0.1:5432/yardsale
#
# Docker / Linux คลาสสิกที่มี role postgres:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/yardsale

JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_BASE=/uploads

# Optional: คั่นด้วย comma ถ้าต้องการจำกัด origin (ค่าเริ่ม = รับทุก origin ที่ส่งมา)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# seed-demo.js — บัญชีแอดมินสำหรับหน้า /admin (ค่าเริ่ม)
# SEED_ADMIN_EMAIL=admin@demo.local
# SEED_ADMIN_PASSWORD=admin123456
# รหัสแอดมินเดิมลืม: SEED_RESET_ADMIN_PASSWORD=1 npm run db:seed
